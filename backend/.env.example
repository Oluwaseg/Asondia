# Local PostgreSQL (development)
# Create DB first: CREATE DATABASE asondia;
# We use local Postgres — NOT Prisma Postgres / Prisma Compute DB for now.
DATABASE_URL="postgresql://postgres:password@localhost:5432/asondia"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"
LOCATION_DB_THROTTLE_MS=20000
